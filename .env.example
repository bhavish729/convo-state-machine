# LLM Provider: openai | anthropic | gemini
TARA_LLM_PROVIDER=openai

# OpenAI
TARA_OPENAI_API_KEY=sk-...
TARA_OPENAI_MODEL=gpt-4o

# Anthropic
TARA_ANTHROPIC_API_KEY=sk-ant-...
TARA_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini
TARA_GOOGLE_API_KEY=...
TARA_GOOGLE_MODEL=gemini-2.0-flash

# LLM Parameters
TARA_LLM_TEMPERATURE=0.3
TARA_LLM_MAX_TOKENS=1024

# ElevenLabs Voice
TARA_ELEVENLABS_API_KEY=...
TARA_ELEVENLABS_VOICE_ID=...

# Server
TARA_HOST=0.0.0.0
TARA_PORT=8000
TARA_DEBUG=true

# LangSmith (optional — enables automatic tracing)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=...
LANGCHAIN_PROJECT=tara-dev
